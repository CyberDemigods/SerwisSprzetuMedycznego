---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt" description="Skontaktuj się z nami — zgłoś serwis sprzętu medycznego, zapytaj o wycenę lub umów przegląd techniczny.">
  <section class="bg-gradient-to-br from-secondary to-primary-dark py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Kontakt</h1>
      <p class="text-slate-300 text-lg max-w-2xl">
        Zgłoś usterkę, zapytaj o wycenę lub umów przegląd. Odpowiadamy w ciągu 24 godzin.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-secondary mb-6">Formularz zgłoszeniowy</h2>
          <form class="space-y-6" id="contact-form">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-text mb-2">Imię i nazwisko *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                  placeholder="Jan Kowalski"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-text mb-2">Nazwa placówki</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                  placeholder="Nazwa kliniki / szpitala"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-text mb-2">E-mail *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                  placeholder="jan@example.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-text mb-2">Telefon *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                  placeholder="+48 000 000 000"
                />
              </div>
            </div>

            <div>
              <label for="device" class="block text-sm font-medium text-text mb-2">Typ urządzenia</label>
              <select
                id="device"
                name="device"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-white"
              >
                <option value="">Wybierz kategorię...</option>
                <option value="rehabilitacyjny">Sprzęt rehabilitacyjny</option>
                <option value="diagnostyczny">Sprzęt diagnostyczny</option>
                <option value="chirurgiczny">Sprzęt chirurgiczny</option>
                <option value="laboratoryjny">Sprzęt laboratoryjny</option>
                <option value="stomatologiczny">Sprzęt stomatologiczny</option>
                <option value="szpitalny">Sprzęt szpitalny</option>
                <option value="inny">Inny</option>
              </select>
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-text mb-2">Rodzaj usługi</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-white"
              >
                <option value="">Wybierz usługę...</option>
                <option value="naprawa">Naprawa</option>
                <option value="przeglad">Przegląd techniczny</option>
                <option value="kalibracja">Kalibracja</option>
                <option value="umowa">Umowa serwisowa</option>
                <option value="konsultacja">Konsultacja</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-text mb-2">Opis problemu / wiadomość *</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-y"
                placeholder="Opisz usterkę lub zapytanie..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full sm:w-auto px-8 py-4 bg-primary text-white rounded-xl text-lg font-semibold hover:bg-primary-dark transition-colors shadow-lg shadow-primary/25"
            >
              Wyślij zgłoszenie
            </button>
          </form>
        </div>

        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-secondary mb-6">Dane kontaktowe</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-secondary">Adres</div>
                <div class="text-text-light text-sm">Opole, Polska</div>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-secondary">Telefon</div>
                <a href="tel:+48000000000" class="text-primary hover:underline text-sm">+48 000 000 000</a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-secondary">E-mail</div>
                <a href="mailto:kontakt@serwis-sprzetu-medycznego.pl" class="text-primary hover:underline text-sm">kontakt@serwis-sprzetu-medycznego.pl</a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-secondary">Godziny pracy</div>
                <div class="text-text-light text-sm">Pon–Pt: 8:00–16:00</div>
                <div class="text-text-light text-sm">Awarie: 24/7</div>
              </div>
            </div>
          </div>

          <div class="mt-8 p-6 bg-accent/10 rounded-2xl border border-accent/20">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <span class="font-semibold text-secondary">Pilna awaria?</span>
            </div>
            <p class="text-text-light text-sm">
              W przypadku pilnych awarii sprzętu medycznego zadzwoń bezpośrednio.
              Reagujemy w trybie ekspresowym.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
