---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article>
    <header class="bg-gradient-to-br from-secondary to-primary-dark py-16 lg:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors mb-6 text-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Powrót do bloga
        </a>
        <div class="flex items-center gap-3 mb-4">
          <time class="text-sm text-slate-400">{new Date(post.data.date).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <span class="text-slate-600">|</span>
          <span class="text-sm text-slate-400">{post.data.author}</span>
        </div>
        <h1 class="text-3xl lg:text-4xl font-extrabold text-white leading-tight">{post.data.title}</h1>
        {post.data.image && (
          <div class="mt-8 rounded-xl overflow-hidden shadow-lg max-w-2xl">
            <img src={post.data.image} alt="" class="w-full h-auto" />
          </div>
        )}
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs bg-white/10 text-white/80 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <div class="prose prose-lg prose-slate max-w-none prose-headings:text-secondary prose-a:text-primary hover:prose-a:text-primary-dark prose-strong:text-text">
        <Content />
      </div>

      <div class="mt-12 pt-8 border-t border-slate-200">
        <a href="/blog" class="inline-flex items-center gap-2 text-primary hover:text-primary-dark transition-colors font-medium">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Wszystkie artykuły
        </a>
      </div>
    </div>
  </article>
</Layout>
