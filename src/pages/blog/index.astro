---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog" description="Artykuły, poradniki i aktualności ze świata serwisu sprzętu medycznego. Praktyczna wiedza dla placówek medycznych.">
  <section class="bg-gradient-to-br from-secondary to-primary-dark py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Blog</h1>
      <p class="text-slate-300 text-lg max-w-2xl">
        Praktyczna wiedza o serwisie i eksploatacji sprzętu medycznego.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <p class="text-text-light text-center py-12">Brak artykułów. Wkrótce pojawią się nowe treści!</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="group block">
              <article class="h-full rounded-2xl border border-slate-200 overflow-hidden hover:border-primary/30 hover:shadow-lg transition-all duration-300">
                <div class="h-48 bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
                  <svg class="w-16 h-16 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6V7.5z" />
                  </svg>
                </div>
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-3">
                    <time class="text-xs text-text-light">{new Date(post.data.date).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                    {post.data.tags[0] && (
                      <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">{post.data.tags[0]}</span>
                    )}
                  </div>
                  <h2 class="text-lg font-bold text-secondary mb-2 group-hover:text-primary transition-colors">{post.data.title}</h2>
                  <p class="text-text-light text-sm leading-relaxed">{post.data.description}</p>
                </div>
              </article>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
