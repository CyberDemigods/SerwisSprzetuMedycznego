---
const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
            </svg>
          </div>
          <div>
            <span class="font-bold text-lg leading-tight block">Serwis Sprzętu</span>
            <span class="text-primary-light text-sm font-medium leading-tight block">Medycznego</span>
          </div>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          Profesjonalny serwis sprzętu medycznego na terenie całej Polski. Naprawy, przeglądy i konserwacja.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4">Usługi</h3>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="/uslugi" class="hover:text-white transition-colors">Naprawy sprzętu</a></li>
          <li><a href="/uslugi" class="hover:text-white transition-colors">Przeglądy techniczne</a></li>
          <li><a href="/uslugi" class="hover:text-white transition-colors">Kalibracja urządzeń</a></li>
          <li><a href="/uslugi" class="hover:text-white transition-colors">Umowy serwisowe</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4">Firma</h3>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="/o-firmie" class="hover:text-white transition-colors">O nas</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4">Kontakt</h3>
        <ul class="space-y-2 text-sm text-slate-400">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
            </svg>
            Opole, Polska
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a href="tel:+48000000000" class="hover:text-white transition-colors">+48 000 000 000</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:kontakt@serwis-sprzetu-medycznego.pl" class="hover:text-white transition-colors">kontakt@serwis-sprzetu-medycznego.pl</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Pon–Pt: 8:00–16:00
          </li>
          <li class="text-xs text-slate-500 mt-2">NIP: 0000000000</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-700 text-center text-sm text-slate-500 space-y-1">
      <p>&copy; {currentYear} Serwis Sprzętu Medycznego. Wszelkie prawa zastrzeżone.</p>
      <p>Forged by <a href="https://cyberdemigods.com/" target="_blank" rel="noopener" class="text-slate-400 hover:text-white transition-colors">CyberDemigods</a></p>
    </div>
  </div>
</footer>
