---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Strona główna' },
  { href: '/uslugi', label: 'Usługi' },
  { href: '/o-firmie', label: 'O firmie' },
  { href: '/blog', label: 'Blog' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 lg:h-20">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
          </svg>
        </div>
        <div class="hidden sm:block">
          <span class="text-lg font-bold text-secondary leading-tight block">Serwis Sprzętu</span>
          <span class="text-sm text-primary font-medium leading-tight block">Medycznego</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'bg-primary/10 text-primary'
                : 'text-text-light hover:text-primary hover:bg-primary/5',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/kontakt"
          class="ml-4 px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary-dark transition-colors"
        >
          Zgłoś serwis
        </a>
      </div>

      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-text-light hover:bg-surface-alt transition-colors"
        aria-label="Otwórz menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <div class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-3 rounded-lg text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'bg-primary/10 text-primary'
                : 'text-text-light hover:text-primary hover:bg-primary/5',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/kontakt"
          class="mt-2 px-4 py-3 bg-primary text-white rounded-lg text-sm font-semibold text-center hover:bg-primary-dark transition-colors"
        >
          Zgłoś serwis
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
