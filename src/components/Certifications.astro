---
const certs = [
  {
    title: 'PN-EN 62353',
    description: 'Badania okresowe i badania po naprawie medycznych urządzeń elektrycznych',
    icon: 'shield',
  },
  {
    title: 'PN-EN 60601-1',
    description: 'Bezpieczeństwo i zasadnicze działanie medycznych urządzeń elektrycznych',
    icon: 'bolt',
  },
  {
    title: 'ISO 9001:2015',
    description: 'System zarządzania jakością — zapewnienie najwyższych standardów usług',
    icon: 'badge',
  },
  {
    title: 'Autoryzacje producenckie',
    description: 'Autoryzowany serwis partnerów — dostęp do oryginalnych części i dokumentacji',
    icon: 'star',
  },
];
---

<section class="py-16 lg:py-24 bg-surface-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-secondary mb-4">Certyfikaty i normy</h2>
      <p class="text-text-light text-lg">
        Działamy zgodnie z obowiązującymi normami i standardami branżowymi, gwarantując bezpieczeństwo i jakość usług.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {certs.map((cert) => (
        <div class="bg-white p-6 rounded-2xl border border-slate-200 text-center hover:shadow-md hover:border-primary/20 transition-all">
          <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
            {cert.icon === 'shield' && (
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            )}
            {cert.icon === 'bolt' && (
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            )}
            {cert.icon === 'badge' && (
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            )}
            {cert.icon === 'star' && (
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            )}
          </div>
          <h3 class="text-lg font-bold text-secondary mb-2">{cert.title}</h3>
          <p class="text-text-light text-sm leading-relaxed">{cert.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
